# ============================================================
# .env.deploy.example для DEPLOY REPO (docker-compose.deploy.yaml)
# Мінімально необхідні змінні для запуску готової системи з Docker Hub.
# ============================================================

# --- Koha image (краще pin по digest у prod) ---
# Наприклад: pinokew/koha@sha256:...
KOHA_IMAGE=pinokew/koha:25.05

# --- Koha runtime ---
KOHA_INSTANCE=library
KOHA_DOMAIN=example.local
KOHA_TIMEZONE=Europe/Kyiv
KOHA_OPAC_PORT=8080
KOHA_INTRANET_PORT=8081

# --- Database ---
DB_HOST=db
DB_NAME=koha_library
DB_USER=koha_db
DB_PASS=change_me_db_pass
DB_ROOT_PASS=change_me_db_root_pass
DB_SERVER_ID=1
DB_LOG_BIN_BASENAME=mysql-bin
DB_BINLOG_FORMAT=ROW
DB_BINLOG_ROW_IMAGE=FULL
DB_SYNC_BINLOG=1
DB_BINLOG_EXPIRE_DAYS=7

# --- RabbitMQ ---
RABBITMQ_USER=koha_mq
RABBITMQ_PASS=change_me_mq_pass

# --- Volumes ---
VOL_DB_PATH=$HOME/Koha/koha-deploy-volumes/mysql_data
VOL_ES_PATH=$HOME/Koha/koha-deploy-volumes/elastic_data
VOL_KOHA_CONF=$HOME/Koha/koha-deploy-volumes/koha_config
VOL_KOHA_DATA=$HOME/Koha/koha-deploy-volumes/koha_data
VOL_KOHA_LOGS=$HOME/Koha/koha-deploy-volumes/koha_logs

# --- Backup/Restore ---
BACKUP_PATH=/var/backups/koha
BACKUP_OFFSITE_PATH=/home/pinokew/GoogleDrive/kdv-drive/KDV_Backups/Koha
BACKUP_OFFSITE_EXCLUDE_FILES=koha_data.tar.gz
BACKUP_TMP_ROOT=/tmp
BACKUP_RETENTION_DAYS=30
BACKUP_INCLUDE_LOGS=true
BACKUP_INCLUDE_ES_DATA=false

RESTORE_SOURCE_DIR=
RESTORE_REINDEX=true
RESTORE_VERIFY=true
RESTORE_LOGS=false
RESTORE_ES_DATA=false
PITR_TARGET_DATETIME=

# --- Optional overrides ---
KOHA_LANGS=uk-UA
USE_ELASTICSEARCH=true
ELASTICSEARCH_HOST=es:9200
MEMCACHED_SERVERS=memcached:11211

# Optional server names (if need explicit vhost hostnames)
KOHA_OPAC_SERVERNAME=
KOHA_INTRANET_SERVERNAME=

Optional side images (defaults are set in compose)
MARIADB_IMAGE=docker.io/mariadb:11
ES_VERSION=8.19.6
RABBITMQ_VERSION=3-management
MEMCACHED_VERSION=1.6
ES_IMAGE=koha-local-es:8.19.6
RABBITMQ_IMAGE=koha-local-rabbitmq:3-management
MEMCACHED_IMAGE=koha-local-memcached:1.6
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.2.0

# Optional setup pipeline tuning
# KOHA_SETUP_FAIL_FAST=false
# KOHA_SETUP_REQUIRED_STEPS=00-env-checks.sh
# KOHA_SETUP_SKIP_STEPS=
# KOHA_SETUP_ONLY_STEPS=

# Optional resource limits (runtime hardening / capacity control)
# KOHA_MEM_LIMIT=2g
# KOHA_CPUS=1.50
# DB_MEM_LIMIT=2g
# DB_CPUS=1.50
# RABBITMQ_MEM_LIMIT=512m
# RABBITMQ_CPUS=1.00
# ES_MEM_LIMIT=1g
# ES_CPUS=1.00
# MEMCACHED_MEM_LIMIT=256m
# MEMCACHED_CPUS=0.50
# TUNNEL_MEM_LIMIT=128m
# TUNNEL_CPUS=0.25

# Optional docker log rotation (json-file)
# LOG_MAX_SIZE=10m
# LOG_MAX_FILE=3

# Optional centralized docker logs export to host path
# LOG_EXPORT_ROOT=$HOME/Koha/koha-deploy-volumes/koha_logs/centralized/docker
# LOG_STATE_FILE=$HOME/Koha/koha-deploy-volumes/koha_logs/centralized/.docker_logs_since
# LOG_FIRST_SINCE=24h

# Optional only when using `--profile tunnel`
CLOUDFLARE_TOKEN=
